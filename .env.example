# Environment Variables
PORT=3000
NODE_ENV=development

# MySQL Database - Use strong passwords in production!
DB_HOST=localhost
DB_PORT=3306
DB_USER=clinivoice
DB_PASSWORD=your_secure_password_here
DB_NAME=clinivoice_v2

# Google Gemini API Key (get from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (optional)
OPENAI_API_KEY=your_openai_api_key_here

# AI Provider: 'gemini', 'openai', or 'auto'
AI_PROVIDER=auto

# Encryption key for transcripts (32 bytes, base64 encoded)
# Generate with: openssl rand -base64 32
ENC_KEY=your_base64_encoded_32_byte_key_here

# JWT Secret for session tokens (generate with: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here

# Allowed origin for CORS (your production domain)
ALLOWED_ORIGIN=https://your-domain.com

# Admin password (set a strong password for production!)
# If not set, default is: CliniVoice$ecureAdmin2026!
ADMIN_PASSWORD=YourStrongAdminPassword123!
